#!/bin/bash
#
# retry-failed-md5-downloads-by-apt-mirror:  Check failed packages downloaded by apt-mirror and try download if the md5 hash is wrong
# 2022-2026 Esteban M. Navas Martín <algodelinux@gmail.com>

RETRIES=3

if [[ $1 != "" ]]; then
   mirrorlist=$1
else
   mirrorlist="/etc/apt/mirror.list"
fi

BASE_PATH=$(grep -F "set base_path" $mirrorlist | grep -v ^# | sed -e "s/^.*set.base_path[[:space:]]*//")
[ -z $BASE_PATH ] && BASE_PATH=$(grep -F "set base_path" $mirrorlist | sed -e "s/^.*set.base_path[[:space:]]*//")

echo "Scanning list of failed downloaded packages by apt-mirror using file: $BASE_PATH/var/FAILED"
echo "Reading and Checking MD5 checksum using file: $BASE_PATH/var/MD5"
echo "Failed packages list will be stored in: $BASE_PATH/var/FAILED"

# -----------------------------------------------------------
# Función para descargar con reintentos
# -----------------------------------------------------------
download_with_retries() {
    local url="$1"
    local dest="$2"
    local destdir="$(dirname $dest)"
    local attempt
    local success=false

    mkdir -p $destdir

    for attempt in $(seq 1 $RETRIES); do
        echo "  → Download attempt $attempt of $RETRIES: $url"
        wget -q --timeout=30 --tries=3 -O "$dest" "$url"
        if [ $? -eq 0 ]; then
            echo "  ✓ Download succeeded: $dest"
            success=true
            break
        else
            echo "  ⚠️ Download failed, retrying..."
            sleep 2
        fi
    done

    if ! $success; then
        echo "  ❌ Failed to download $dest after $RETRIES attempts"
        return 1
    fi
    return 0
}

if [ -f "$BASE_PATH/var/FAILED" ]; then
# -----------------------------------------------------------
# Procesar paquetes
# -----------------------------------------------------------
while IFS='' read -r packageurl || [ -n "$packageurl" ]; do

    package=$(echo $packageurl | sed 's#.*/##')

    line=$(grep "$package" "$BASE_PATH/var/MD5")

    if [ -n "$line" ]; then
       echo "Checking: $line"

       checksum=$(echo $line | cut -d' ' -f1)
       filename=$(echo $line | cut -d' ' -f2)
       dest="$BASE_PATH/mirror/$filename"

       # Si el paquete no existe en el mirror, tratamos de descargarlo
       [ ! -f "$dest" ] && download_with_retries "$filename" "$dest"

       # Comprobar MD5
       echo "$checksum $BASE_PATH/mirror/$filename"
       echo "$checksum $BASE_PATH/mirror/$filename" | md5sum -c -
       RESULT=$?

       if [ $RESULT -ne 0 ];then
           # Tratamos de descargar el paquete cuyo hash no coincidía
           echo "Checksum failed, retrying download..."
           download_with_retries "$filename" "$dest"

           # Volvemos a comprobar el hash del paquete que acabamos de descargar
           echo "$checksum  $dest" > /tmp/check.tmp
           md5sum -c /tmp/check.tmp
           SUBRESULT=$?
           rm -f /tmp/check.tmp

           if [ $SUBRESULT -ne 0 ];then
               # Si el hash del fichero recien descargado tampoco coincide...
               echo "Sorry failed checksum again for file: $dest"
               echo "$packageurl" | tee -a "$BASE_PATH/var/FAILED"
           fi
       else
          sed -i "\|${filename##*/}|d" "$BASE_PATH/var/FAILED"
       fi
    fi
done < "$BASE_PATH/var/FAILED"
fi
